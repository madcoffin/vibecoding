#!/bin/bash
# Launcher script for Handwriting Recognizer
# Locates Python, activates the correct environment, and runs app.py.

# Directory where this .app bundle lives
APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

# ── Find Python ───────────────────────────────────────────────────────────
# Prefer the Homebrew Python that has the required packages installed.
PYTHON=""
for candidate in \
    /opt/homebrew/opt/python@3.14/bin/python3.14 \
    /opt/homebrew/bin/python3 \
    /usr/local/bin/python3 \
    /usr/bin/python3 \
    python3; do
    if command -v "$candidate" &>/dev/null; then
        PYTHON="$candidate"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    osascript -e 'display alert "Python not found" message "Could not find Python 3. Please install it via Homebrew: brew install python" as critical'
    exit 1
fi

# ── Verify required packages ──────────────────────────────────────────────
MISSING=$("$PYTHON" - <<'EOF'
import importlib, sys
needed = ["torch", "PIL", "numpy", "tkinter"]
missing = [m for m in needed if importlib.util.find_spec(m) is None]
print(" ".join(missing))
EOF
)

if [ -n "$MISSING" ]; then
    osascript -e "display alert \"Missing packages\" message \"Please install: $MISSING\" as warning"
    exit 1
fi

# ── Launch the app ────────────────────────────────────────────────────────
cd "$APP_DIR"
exec "$PYTHON" "$APP_DIR/app.py"
